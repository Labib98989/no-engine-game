{
  "version": 6,
  "configurePresets": [
    {
      "name": "msvc-x64",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/msvc-x64",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": { "VCPKG_TARGET_TRIPLET": "x64-windows" }
    },
    {
      "name": "msvc-x64-asan",
      "inherits": "msvc-x64",
      "binaryDir": "${sourceDir}/build/msvc-x64-asan",
      "cacheVariables": { "ENABLE_ASAN": "ON" }
    }
  ],
  "buildPresets": [
    { "name": "debug",   "configurePreset": "msvc-x64", "configuration": "Debug" },
    { "name": "release", "configurePreset": "msvc-x64", "configuration": "Release" }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "msvc-x64",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    }
  ]
}
